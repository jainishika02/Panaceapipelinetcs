def parse_sqlserver_jdbc_url(jdbc_url):
    """
    Parses a SQL Server JDBC URL and returns (host, port, database_name).
    Expected format: jdbc:sqlserver://<host>:<port>;database=<dbname>;...
    """
    prefix = "jdbc:sqlserver://"

    if not jdbc_url.startswith(prefix):
        raise ValueError("Invalid SQL Server JDBC URL")

    url_body = jdbc_url[len(prefix):]
    host_port, *params = url_body.split(";")
    host, port = host_port.split(":")

    database_name = None
    for param in params:
        if param.startswith("database="):
            database_name = param.split("=", 1)[1]
            break

    if not database_name:
        raise ValueError("Database name not found in JDBC URL")

    return host, int(port), database_name


