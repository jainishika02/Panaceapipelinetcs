def execute_sp(sp):
    """
    Executes a stored procedure without returning results.
    Commits on success; raises KeyError on failure.
    """
    try:
        cursor = conn.cursor()
        cursor.execute(sp)
        conn.commit()
    except Exception as e:
        print(f"No value returned for given key: {str(e)}.")
        raise KeyError("Unable to fetch the key from HashiCorp")


def execute_sp_output(sp_query):
    """
    Executes a stored procedure and returns Summary and (optionally) Array result sets
    as a dict of records.
    """
    cursor = conn.cursor()
    cursor.execute(sp_query)

    row1 = cursor.fetchall()
    cols1 = [column[0] for column in cursor.description]
    df1 = pd.DataFrame.from_records(row1, columns=cols1)

    if cursor.nextset():
        row2 = cursor.fetchall()
        cols2 = [column[0] for column in cursor.description]
        df2 = pd.DataFrame.from_records(row2, columns=cols2)
        return {
            "Summary": df1.to_dict(orient="records"),
            "Array":   df2.to_dict(orient="records")
        }

    return {"Summary": df1.to_dict(orient="records")}


def execute_sp_output_return_df(sp):
    """
    Executes a stored procedure and returns the result as a Pandas DataFrame.
    Returns None on failure.
    """
    try:
        cursor = conn.cursor()
        cursor.execute(sp)
        columns = [col[0] for col in cursor.description]
        data = cursor.fetchall()
        df = pd.DataFrame(data, columns=columns)
        return df
    except Exception as e:
        print(f"No value returned for given key: {str(e)}.")
        return None
